# Secrets and credentials — never commit these
.env
.env.*
*.key
*.pfx
*.pem
secrets/
credentials/

# Claude Code runtime files
.claude/KILL_SWITCH
.claude/session_*

# Migration runtime
migration/audit/audit_trail.jsonl
migration/audit/sessions.jsonl
migration/audit/*.jsonl.bak

# Active state files (contain workspace-specific details)
migration/state/migration_state.json
migration/state/phase*.json

# Active deployment config (contains workspace IDs)
migration/config/deploy_config.json

# Synapse source artifacts — added by user, not versioned
synapse/

# Fabric output — generated by agents, reviewed before commit
fabric/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
